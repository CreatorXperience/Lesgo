{
  "name": "lesgo",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc && mkdir -p dist/src/generated/prisma && cp -R src/generated/prisma/. dist/src/generated/prisma && node scripts/fix-prisma-esm-imports.mjs",
    "start": "node dist/src/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "dotenv": "^17.3.1",
    "hono": "^4.12.2",
    "pg": "^8.18.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/pg": "^8.16.0",
    "prisma": "^7.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
