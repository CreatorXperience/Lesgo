// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id               String   @id @default(cuid())
  title            String
  description      String?
  createdAt        DateTime @default(now())
  automationStatus Boolean  @default(false)

  candidates Candidate[]
}

model Candidate {
  id String @id @default(cuid())

  // --- identity ---
  name     String?
  email    String?
  phone    String?
  location String?

  // --- raw input ---
  resumeText String?

  // --- job relation ---
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // --- pipeline state ---
  stage CandidateStage @default(APPLIED)

  // --- AI 1: enrichment output ---
  coreSkills           Json?
  experienceSummary    Json?
  externalLinkAnalysis Json?
  overallAssessment    Json?

  // --- AI 2: evaluation output ---
  yearsOfExperience Int?
  skills            Json?
  topSkillsMatch    Json?
  missingSkills     Json?
  education         String?
  lastRole          String?
  seniority         String?

  jobFitScore     Float?
  experienceScore Float?
  skillsScore     Float?
  overallScore    Float?

  strengths      Json?
  weaknesses     Json?
  recommendation Recommendation?

  summary String?

  // --- meta ---
  resumeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Stage {
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  HIRED
}

enum CandidateStage {
  APPLIED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

model Recommendation {
  id String @id @default(cuid())

  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  value RecommendationValue

  confidence Float? // how sure AI is (0-1)
  reasoning  String? // explanation from AI

  strengths Json?
  risks     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RecommendationValue {
  REJECT
  CONSIDER
  SHORTLIST
  STRONG_SHORTLIST
}
